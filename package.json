{
  "name": "her-assistant",
  "version": "1.0.0",
  "description": "Local-first Personal AI Assistant (React + Electron)",
  "main": "native/dist/main.js",
  "scripts": {
    "dev:app": "vite app",
    "dev:demo": "cross-env DEMO_MODE=true vite app",
    "dev:native": "npm run build:app && npm run build:electron && concurrently \"npm run start-agent\" \"electron .\"",
    "start-agent": "ts-node agent/src/index.ts",
    "build:app": "tsc -b && vite build app",
    "build:electron": "tsc -p native/tsconfig.json",
    "build": "npm run build:app && npm run build:electron && electron-builder --win",
    "migrate": "ts-node scripts/migrate.ts",
    "seed": "ts-node scripts/seed.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "keywords": [
    "ai",
    "electron",
    "react",
    "local-first"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.0",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "groq-sdk": "^0.37.0",
    "lucide-react": "^0.292.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "sql.js": "^1.8.0",
    "tailwind-merge": "^3.4.0",
    "ts-morph": "^20.0.0",
    "uuid": "^9.0.1",
    "zustand": "^4.4.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.5",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@types/node-schedule": "^2.1.4",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/sql.js": "^1.4.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jest": "^29.7.0",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.her.assistant",
    "productName": "HER Assistant",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "native/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
