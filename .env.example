# Server Configuration
PORT=3000
NODE_ENV=development

# Application Modes
DEMO_MODE=true
ENABLE_NATIVE_AGENT=true
ENABLE_REMOTE_LLM=true

# Email / SMTP (Optional)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=example@ethereal.email
SMTP_PASS=password

# Security
DB_ENCRYPTION_KEY=change_me_in_production
